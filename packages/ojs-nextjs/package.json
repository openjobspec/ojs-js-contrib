{
  "name": "@openjobspec/nextjs",
  "version": "0.9.0",
  "description": "Next.js helpers for OpenJobSpec",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./server": { "types": "./dist/server.d.ts", "default": "./dist/server.js" },
    "./client": { "types": "./dist/client.d.ts", "default": "./dist/client.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": ["openjobspec", "ojs", "nextjs", "server-actions", "background-jobs"],
  "repository": {
    "type": "git",
    "url": "https://github.com/openjobspec/ojs-js-contrib",
    "directory": "packages/ojs-nextjs"
  },
  "homepage": "https://github.com/openjobspec/ojs-js-contrib/tree/main/packages/ojs-nextjs#readme",
  "bugs": "https://github.com/openjobspec/ojs-js-contrib/issues",
  "peerDependencies": {
    "@openjobspec/sdk": "^0.2.0",
    "next": "^14.0.0 || ^15.0.0"
  },
  "devDependencies": {
    "@openjobspec/sdk": "^0.2.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "license": "Apache-2.0"
}

